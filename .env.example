# =============================================================================
# SAP HANA Express + SAP Business One Development Environment
# Copy this file to .env and adjust the values before running docker-compose
# =============================================================================

# ---------------------------------------------------------------------------
# SAP HANA Express Settings
# ---------------------------------------------------------------------------

# Master password for HANA Express (must meet complexity requirements)
# At least 8 characters, mix of upper/lowercase, digits and special chars
# ⚠  Also update hana/passwords.json to match this value before building.
HANA_MASTER_PASSWORD=HXEHana1

# HANA Express instance number (default 90)
HANA_INSTANCE=90

# Host name to expose HANA Express under (used in SSL/TLS certificate)
HANA_HOSTNAME=hxehost

# HANA system DB user
HANA_SYSTEM_USER=SYSTEM

# Path on the Docker host where HANA data files will be persisted
HANA_DATA_PATH=./volumes/hana/data

# Path on the Docker host where HANA log files will be persisted
HANA_LOG_PATH=./volumes/hana/log

# ---------------------------------------------------------------------------
# SAP Business One Settings
# ---------------------------------------------------------------------------

# B1 server hostname (must resolve inside Docker network)
B1_HOSTNAME=b1server

# B1 SLD server port
B1_SLD_PORT=30000

# B1 Service Layer HTTP port
B1_SL_HTTP_PORT=50000

# B1 Service Layer HTTPS port
B1_SL_HTTPS_PORT=50001

# B1 license server port
B1_LICENSE_PORT=40000

# HANA connection details used by B1 during installation
# (should match the HANA Express settings above)
B1_HANA_HOST=hxehost
B1_HANA_PORT=39017
B1_HANA_USER=SYSTEM
B1_HANA_PASSWORD=HXEHana1

# B1 installation media: place the SAP Business One for HANA Linux package
# (e.g. B1_10.0_FP2508_FOR_HANA_LINUX_X86_64.tar.gz) inside ./b1/media/
B1_INSTALLER_ARCHIVE=B1_10.0_FP2508_FOR_HANA_LINUX_X86_64.tar.gz

# ---------------------------------------------------------------------------
# Network
# ---------------------------------------------------------------------------

# Docker network subnet (change only if it conflicts with your local network)
DOCKER_SUBNET=172.20.0.0/24
